{
  "env": {
    "node": true,
    "commonjs": true,
    "es2021": true,
    "vitest-globals/env": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:node/recommended",
    "prettier"
  ],
  "parserOptions": {
    "ecmaVersion": 12
  },
  "plugins": ["vitest-globals"],
  "rules": {
    "no-console": "warn",
    "node/no-unsupported-features/es-syntax": "off",
    "security/detect-object-injection": "off"
  }
}
