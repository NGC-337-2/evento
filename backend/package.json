{
  "name": "evento-backend",
  "version": "1.0.0",
  "description": "EventO — Online Event Booking & Management Platform API (Node.js + Express + MongoDB)",
  "author": "EventO Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/evento-backend.git"
  },
  "homepage": "https://github.com/your-org/evento-backend#readme",
  "bugs": {
    "url": "https://github.com/your-org/evento-backend/issues"
  },
  "keywords": [
    "event-management",
    "booking-system",
    "nodejs",
    "express",
    "mongodb",
    "stripe",
    "jwt-auth",
    "react-api"
  ],
  "main": "src/server.js",
  "type": "commonjs",
  "engines": {
    "node": ">=18.12.0",
    "npm": ">=9.0.0"
  },
  "os": [
    "linux",
    "darwin",
    "win32"
  ],
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "dev:debug": "nodemon --inspect=0.0.0.0:9229 src/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "cypress run --config-file cypress.config.js",
    "test:e2e:open": "cypress open --config-file cypress.config.js",
    "lint": "eslint src --ext .js,.cjs",
    "lint:fix": "eslint src --ext .js,.cjs --fix",
    "format": "prettier --write \"src/**/*.{js,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,json,md}\"",
    "security:check": "npm audit --audit-level=moderate",
    "security:fix": "npm audit fix",
    "db:seed": "node src/scripts/seedDatabase.js",
    "db:reset": "node src/scripts/resetDatabase.js",
    "build": "echo 'No build step for Node.js backend'",
    "prepare": "husky install",
    "health": "curl -f http://localhost:${PORT:-5000}/api/health || exit 1",
    "precommit": "npm run lint && npm run test"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.5.1",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "hpp": "^0.2.3",
    "joi": "^18.1.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.23.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.10.1",
    "qrcode": "^1.5.4",
    "stripe": "^17.7.0",
    "uuid": "^11.1.0",
    "winston": "^3.19.0",
    "xss-clean": "^0.1.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.1.1",
    "cypress": "^14.3.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.6.0",
    "eslint-plugin-security": "^2.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "nodemon": "^3.1.9",
    "prettier": "^3.5.3",
    "supertest": "^7.1.0",
    "vitest": "^3.1.1"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "overrides": {
    "brace-expansion": "2.0.1",
    "semver": "^7.6.3"
  },
  "lint-staged": {
    "src/**/*.{js,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{json,md}": [
      "prettier --write"
    ]
  },
  "nodemonConfig": {
    "watch": [
      "src",
      ".env"
    ],
    "ignore": [
      "src/tests",
      "src/scripts",
      "*.test.js",
      "*.spec.js"
    ],
    "ext": "js,json",
    "delay": "500",
    "env": {
      "NODE_ENV": "development"
    }
  },
  "vitest": {
    "test": {
      "include": [
        "src/**/*.test.js"
      ],
      "exclude": [
        "src/tests/e2e/**",
        "node_modules/**"
      ],
      "environment": "node",
      "coverage": {
        "provider": "v8",
        "reportsDirectory": "./coverage",
        "thresholds": {
          "lines": 80,
          "branches": 75,
          "functions": 80,
          "statements": 80
        }
      }
    }
  }
}
